generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GameResult {
  id             String   @id @default(cuid())
  userId         String
  dateKey        String
  mode           String   @default("daily-movie")
  status         String
  guessIds       Int[]
  attemptCount   Int
  hintsUsed      Int
  completedAt    DateTime @default(now())
  targetMovieId  Int      @default(0)
  targetTitle    String   @default("")
  targetYear     Int      @default(0)
  targetPoster   String   @default("")
  extraAttempts  Int      @default(0)
  paidHintUsed   Boolean  @default(false)
  paidHintsCount Int      @default(0)

  @@unique([userId, dateKey, mode])
  @@index([userId])
  @@index([userId, completedAt])
}

model UserStats {
  id             String  @id @default(cuid())
  userId         String  @unique
  gamesPlayed    Int     @default(0)
  gamesWon       Int     @default(0)
  currentStreak  Int     @default(0)
  maxStreak      Int     @default(0)
  averageGuesses Float   @default(0)
  lastPlayedDate String?
}

model SavedMovie {
  id         String    @id @default(cuid())
  userId     String
  tmdbId     Int
  title      String
  year       Int
  posterPath String
  genres     String[]
  director   String    @default("")
  overview   String    @default("")
  runtime    Int       @default(0)
  tmdbRating Float     @default(0)
  category   String // "watched" | "watchlist"
  rating     Float?
  review     String?
  watchedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, tmdbId])
  @@index([userId, category])
  @@index([userId, createdAt])
}

model RankedList {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       RankedListItem[]

  @@index([userId])
}

model RankedListItem {
  id         String     @id @default(cuid())
  listId     String
  tmdbId     Int
  title      String
  year       Int
  posterPath String
  genres     String[]
  director   String     @default("")
  overview   String     @default("")
  position   Int

  list       RankedList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, tmdbId])
  @@index([listId, position])
  @@index([listId])
}

model UserWallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Int      @default(0)
  streakFreezes Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model CoinTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  dateKey   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model MovieEmbedding {
  tmdbId    Int                          @id
  title     String
  year      Int
  genres    String[]
  overview  String
  score     Float                        @default(0)
  embedding Unsupported("vector(1536)")

  @@index([year])
}
